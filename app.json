{
  "expo": {
    "name": "Wanasa",
    "slug": "wanasa",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wanasa",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wanasa.app"
    },
    "android": {
      "package": "com.wanasa.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-video",
      "expo-facebook",
      "expo-web-browser"
    ],
    "expo-notifications": {
      "icon": "./assets/images/icon.png",
      "color": "#FF6B2C",
      "sounds": [
        "./assets/sounds/notification.wav"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "fbAppId": "156042655519521",
      "facebookRedirectUri": "https://auth.expo.io/@0911907629you/wanasa",
      "apiUrl": "https://api.wanasa.app/api/v1",
      "wsUrl": "wss://api.wanasa.app/ws",
      "router": {},
      "eas": {
        "projectId": "cdfb222d-b1dc-4f54-9bdf-c88a5ecfd197"
      }
    }
  }
}
